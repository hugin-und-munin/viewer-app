{
  "name": "viewer-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "preview": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist:win": "vite build && electron-builder --win",
    "dist:win:publish": "vite build && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.hugin-und-munin.viewer-app",
    "productName": "Viewer App",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist/**",
      "dist-electron/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "silent": true,
      "allowToChangeInstallationDirectory": false
    },
    "publish": {
      "provider": "github",
      "owner": "hugin-und-munin",
      "repo": "viewer-app",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@mui/material": "^7.3.9",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "esbuild": "^0.27.7",
    "events": "^3.3.0",
    "lodash.isequal": "^4.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/lodash.isequal": "^4.5.8",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.4"
  }
}
